#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Get the commit message
COMMIT_MSG=$(cat "$1")

# Regex for conventional commit format
# Format: type(scope): subject
COMMIT_PATTERN='^(feat|fix|docs|style|refactor|perf|test|chore|ci|revert)(\(.+\))?!?: .{1,}$'

if ! echo "$COMMIT_MSG" | grep -qE "$COMMIT_PATTERN"; then
  echo ""
  echo "❌ Commit message does not follow conventional commits format"
  echo ""
  echo "Format: <type>(<scope>): <subject>"
  echo ""
  echo "Valid types: feat, fix, docs, style, refactor, perf, test, chore, ci, revert"
  echo "Example: feat(auth): add login functionality"
  echo ""
  exit 1
fi

echo "✅ Commit message format is valid"
